{
    "tabWidth": 4,
    "singleQuote": true,
    "trailingComma": "none",
    "printWidth": 120,
    "plugins": ["@prettier/plugin-xml", "prettier-plugin-apex"],
    "overrides": [
        {
            "files": "*.{cls,trigger,apex}",
            "options": {
                "parser": "apex",
                "tabWidth": 4
            }
        },
        {
            "files": "*.xml",
            "options": {
                "parser": "xml",
                "tabWidth": 4
            }
        }
    ]
}
